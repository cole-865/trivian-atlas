{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".test-dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/lib/auth/accessRules.ts",
    "src/lib/auth/actionPlans.ts",
    "services/credit-worker/src/jobRules.ts",
    "services/credit-worker/src/gateway.ts",
    "services/credit-worker/src/processJob.ts",
    "tests/integration/**/*.ts",
    "tests/**/*.ts"
  ]
}
